# Notification/Webhook
WEBHOOK_SIGNING_SECRET=
WEBHOOK_FORWARD_URL=http://127.0.0.1:8787/events

# SMTP (single owner mailbox)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=true

# Google Drive API telemetry
GOOGLE_DRIVE_CREDENTIALS_FILE=
GOOGLE_DRIVE_TOKEN_FILE=
GOOGLE_DRIVE_FOLDER_ID=

# Runtime overrides
FACTORY_DB_PATH=artifacts/factory.db
FACTORY_TASKS_FILE=tasks.sample.json
FACTORY_CORPUS_ROOT=secops_rag
FACTORY_ARTIFACTS_ROOT=artifacts
