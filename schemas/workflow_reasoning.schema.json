{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Detection Workflow Reasoning Trace",
  "description": "Structured reasoning about detection engineering workflows: signals, telemetry, rules, gaps, attack surface.",
  "type": "object",
  "required": ["signals", "correlation", "udm_mapping", "gap_analysis", "rule_logic", "implementation_code", "validation"],
  "properties": {
    "signals": {
      "type": "array",
      "description": "Relevant telemetry signals and data sources",
      "items": {
        "type": "object",
        "required": ["name", "source", "description"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Signal name (e.g., 'process_execution', 'script_block_logging')"
          },
          "source": {
            "type": "string",
            "description": "Telemetry source (e.g., 'Windows Event ID 4688', 'EDR')"
          },
          "description": {
            "type": "string",
            "description": "What this signal captures about the threat"
          },
          "criticality": {
            "type": "string",
            "enum": ["primary", "supporting", "optional"],
            "description": "Importance to detection"
          }
        }
      }
    },
    "correlation": {
      "type": "object",
      "description": "How signals relate to threat behavior and defense evasion",
      "required": ["threat_behavior", "mitre_techniques", "reasoning"],
      "properties": {
        "threat_behavior": {
          "type": "string",
          "description": "What the adversary is trying to do"
        },
        "mitre_techniques": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["technique_id", "tactic"],
            "properties": {
              "technique_id": {"type": "string"},
              "tactic": {"type": "string"},
              "description": {"type": "string"}
            }
          }
        },
        "reasoning": {
          "type": "string",
          "description": "Why these signals + correlation matter for this threat"
        }
      }
    },
    "udm_mapping": {
      "type": "object",
      "description": "Chronicle UDM or generic detection schema fields",
      "required": ["fields", "query_template"],
      "properties": {
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["field_name", "source", "description"],
            "properties": {
              "field_name": {"type": "string"},
              "source": {"type": "string"},
              "description": {"type": "string"},
              "examples": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "query_template": {
          "type": "string",
          "description": "Example UDM query or correlation rule template"
        }
      }
    },
    "gap_analysis": {
      "type": "object",
      "description": "Coverage gaps and how to address them",
      "required": ["current_coverage", "missing_gaps", "recommendations"],
      "properties": {
        "current_coverage": {
          "type": "string",
          "description": "What detections likely already exist"
        },
        "missing_gaps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["gap", "impact", "requirement"],
            "properties": {
              "gap": {"type": "string"},
              "impact": {"type": "string"},
              "requirement": {"type": "string"},
              "priority": {
                "type": "string",
                "enum": ["critical", "high", "medium", "low"]
              }
            }
          }
        },
        "recommendations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["recommendation", "effort"],
            "properties": {
              "recommendation": {"type": "string"},
              "effort": {"type": "string", "enum": ["low", "medium", "high"]},
              "preconditions": {"type": "string"}
            }
          }
        }
      }
    },
    "rule_logic": {
      "type": "object",
      "description": "Detection rule structure and logic",
      "required": ["rule_name", "evidence", "correlation_logic", "alert_confidence"],
      "properties": {
        "rule_name": {"type": "string"},
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["evidence_type", "condition"],
            "properties": {
              "evidence_type": {"type": "string"},
              "condition": {"type": "string"},
              "source": {"type": "string"}
            }
          }
        },
        "correlation_logic": {
          "type": "string",
          "description": "How evidence combines (e.g., 'all_present_within 5m')"
        },
        "alert_confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "description": "Confidence in this detection"
        }
      }
    },
    "implementation_code": {
      "type": "object",
      "description": "Practical rule code (YARA, UDM query, SOAR, etc.)",
      "required": ["rule_format", "code_snippet"],
      "properties": {
        "rule_format": {
          "type": "string",
          "enum": ["yara", "udm_query", "splunk_spl", "sigma", "soar_yaml", "generic"]
        },
        "code_snippet": {
          "type": "string",
          "description": "Actual detection rule or query code"
        },
        "comments": {
          "type": "string",
          "description": "Inline explanation of key logic"
        }
      }
    },
    "validation": {
      "type": "object",
      "description": "Practical constraints and false positive considerations",
      "required": ["assumptions", "false_positive_mitigation", "constraints"],
      "properties": {
        "assumptions": {
          "type": "array",
          "items": {"type": "string"},
          "description": "What must be true for this detection to work"
        },
        "false_positive_mitigation": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["fp_scenario", "mitigation"],
            "properties": {
              "fp_scenario": {"type": "string"},
              "mitigation": {"type": "string"}
            }
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["constraint", "impact"],
            "properties": {
              "constraint": {"type": "string"},
              "impact": {"type": "string"}
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Training metadata and lineage",
      "properties": {
        "source_corpus": {"type": "string"},
        "threat_category": {"type": "string"},
        "domain": {
          "type": "string",
          "pattern": "^D[1-9]$",
          "description": "Primary domain (D1-D9)"
        },
        "secondary_domains": {
          "type": "array",
          "items": {"type": "string", "pattern": "^D[1-9]$"}
        },
        "example_type": {
          "type": "string",
          "enum": ["positive", "negative", "boundary_case"]
        }
      }
    }
  }
}
